# Copy this file to .env and fill in real values.
# Do NOT commit .env. The .gitignore covers it.

# IBM Cloud API key for the hackathon-provisioned account.
# Generated at: https://cloud.ibm.com/iam/apikeys
IBM_CLOUD_API_KEY=replace-me

# watsonx.ai project ID (found in the project's "Manage" tab on the
# watsonx.ai dashboard, or via the Prompt Lab "Developer access" panel).
WATSONX_PROJECT_ID=replace-me

# watsonx.ai endpoint URL — Dallas region for the hackathon.
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# watsonx Orchestrate instance URL (from the Orchestrate environment
# launched from the IBM Cloud resource list).
ORCHESTRATE_INSTANCE_URL=replace-me

# Optional — model override (default is granite-3-8b-instruct).
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct

# ─── Coordinator chat mode (Orchestrate runs API) ──────────────────────────
# Set these to make the React frontend's "Coordinator" pill route through
# your deployed Coordinator agent in Orchestrate. Without them, Coordinator
# mode prints a setup hint and the user has to switch back to Granite.
#
# ORCHESTRATE_AGENT_URL — full URL to the Orchestrate runs endpoint:
#   https://api.<region>.watson-orchestrate.cloud.ibm.com/instances/<instance-id>/v1/orchestrate/runs
# The `?stream=true` query param is added automatically if you leave it off.
#
# ORCHESTRATE_AGENT_ID — the agent UUID from your Orchestrate embed config
# (the `agentId` field under chatOptions). Looks like:
#   dec71955-29db-40dd-b7d8-1e7a1b4cbfaa
#
# ORCHESTRATE_API_KEY — optional dedicated Orchestrate API key. If blank,
# the proxy reuses IBM_CLOUD_API_KEY via IAM exchange (cached ~45 min).
ORCHESTRATE_AGENT_URL=
ORCHESTRATE_AGENT_ID=
ORCHESTRATE_API_KEY=
