# Copy this file to .env and fill in real values.
# Do NOT commit .env. The .gitignore covers it.

# IBM Cloud API key for the hackathon-provisioned account.
# Generated at: https://cloud.ibm.com/iam/apikeys
IBM_CLOUD_API_KEY=replace-me

# watsonx.ai project ID (found in the project's "Manage" tab on the
# watsonx.ai dashboard, or via the Prompt Lab "Developer access" panel).
WATSONX_PROJECT_ID=replace-me

# watsonx.ai endpoint URL — Dallas region for the hackathon.
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# watsonx Orchestrate instance URL (from the Orchestrate environment
# launched from the IBM Cloud resource list).
ORCHESTRATE_INSTANCE_URL=replace-me

# Optional — model override (default is granite-3-8b-instruct).
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct

# ─── Coordinator chat mode (Orchestrate path) ──────────────────────────────
# Set these to make the React frontend's "Coordinator" chat mode route
# through your deployed Coordinator agent in Orchestrate. Without them,
# Coordinator mode prints a setup hint and falls back to Granite.
#
# Where to find ORCHESTRATE_AGENT_URL:
#   In the Orchestrate agent builder, open the Coordinator agent → look for
#   "Deploy → API", "Embed agent", or "Programmatic access". Copy the
#   chat-completions URL it shows. It typically ends in `/chat/completions`.
#
# Where to find ORCHESTRATE_API_KEY:
#   - If your instance uses a dedicated Orchestrate API key, paste it here.
#   - If it accepts IBM Cloud IAM, leave this blank — IBM_CLOUD_API_KEY will
#     be exchanged for a bearer token at request time.
ORCHESTRATE_AGENT_URL=
ORCHESTRATE_API_KEY=
